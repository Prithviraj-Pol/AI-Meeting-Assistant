rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Profiles Collection
    match /profiles/{userId} {
      allow read: if isAuthenticated(); // Anyone authenticated can read profiles (useful for shared meetings)
      allow write: if request.auth.uid == userId; // Users can only write their own profile
    }

    // Meetings Collection
    match /meetings/{meetingId} {
      // Allow reading if the user is the owner
      allow read: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
      
      // Allow creating if the user is authenticated and setting themselves as owner
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      
      // Allow updating/deleting if the user owns the document
      allow update, delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }
  }
}
